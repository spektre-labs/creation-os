# Creation OS — environment example.  Copy to .env locally (which is
# git-ignored) and never commit the real .env.  The pre-commit hook
# rejects any .env* file that is not .env.example.

# ---- Core kernel flags ---------------------------------------------------
# Override CC for a sanitizer / hardened build:
#   CC=clang
# CC=clang

# Pin build epoch for reproducible builds (defaults to 2026-01-01):
#   SOURCE_DATE_EPOCH=1767225600
# SOURCE_DATE_EPOCH=1767225600

# ---- v60 σ-Shield runtime flags -----------------------------------------
# Disable integrity check (intended ONLY for local unit tests):
#   COS_V60_ENFORCE_INTEGRITY=0
# COS_V60_ENFORCE_INTEGRITY=1

# σ-intent gate thresholds (defaults: 1.00 / 0.65):
#   COS_V60_SIGMA_HIGH=1.00
#   COS_V60_ALPHA_DOM=0.65
# COS_V60_SIGMA_HIGH=1.00
# COS_V60_ALPHA_DOM=0.65

# ---- v59 σ-Budget flags (optional) ---------------------------------------
#   COS_V59_BUDGET_MAX=128
#   COS_V59_BUDGET_MIN=8

# ---- local observability -------------------------------------------------
# Path for the v57 Verified Agent aggregate report (default: stdout):
#   COS_V57_REPORT_PATH=.build/verify_agent.log

# ---- NO SECRETS ABOVE THIS LINE ------------------------------------------
# If a key is ever needed, read it from a secret manager (1Password CLI,
# Bitwarden CLI, gopass) at runtime — never from .env.
