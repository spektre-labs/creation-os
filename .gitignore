# ------------------------------------------------------------------
# Creation OS .gitignore — compact, glob-based.
# Rule of thumb: keep this file small. If a generated artefact pattern
# needs more than one line, prefer a glob ("/creation_os_v*") with an
# explicit re-include ("!/creation_os_v*.c") over enumerating versions.
# ------------------------------------------------------------------

# Build trees
.build/
build/
*.o
*.sig
*.dSYM/

# Attestations / SBOM / provenance (generated locally; CI emits canonical)
SBOM.json
ATTESTATION.json
ATTESTATION.sig
PROVENANCE.json

# Canonical root "creation_os" binary (keep the Python package tracked)
/creation_os
!/python/creation_os/

# All versioned kernel binaries + asan/ubsan/hardened/.dSYM variants
# (Re-include the .c / .h / .md sources that live at root.)
/creation_os_v*
!/creation_os_v*.c
!/creation_os_v*.h
!/creation_os_v*.md

# Other root-level binary wrappers
/creation_os_openai_stub
/creation_os_suite_stub
/creation_os_native_m4
/creation_os_proxy
/creation_os_mcp
/creation_os_server*
/creation_os_sigma_*
/creation_os_inplace_ttt
/creation_os_agi_selfplay
/creation_os_agi_distill
/creation_os_agi_meta
/creation_os_ultra_*
/creation_os_iron_gate
/cos
/cos-*
/license_attest
/license_attest_hardened
/libcos_plugin_demo.dylib
/libcos_plugin_demo.so
/test_bsc
/test_sigma_pipeline_integration

# Microbench binaries at root
/cos_lm
/tokenizer_throughput
/binding_fidelity
/vocab_scaling
/vs_transformer
/oracle_speaks
/oracle_ultimate
/gemm_vs_bsc
/coherence_gate_batch
/hv_agi_gate_neon
/genesis
/qhdc

# Runtime logs / transcripts / repro bundles
/cos_chat_transcript.jsonl
/repro_bundle.txt
/repro_bundle.json
metrics/session_*.jsonl

# Local environment overrides (use .env.example as template)
.env
.env.*
!.env.example

# macOS / IDE / language caches
.DS_Store
.cursor/
__pycache__/
.pytest_cache/
.venv/
.venv-bitnet/

# macOS Finder "duplicate" files and directories (whole-tree accidents)
* 2
* 2.*

# Nix / direnv / Earthly / Zig / Rust / Nim shims
.direnv/
result
result-*
zig-out/
.zig-cache/
.earthly/
nimcache/
infra/cos_gate/target/
polyglot/nim/cos_gate

# Hardware build dirs (Chisel / Rust gate / formal agency)
hw/chisel/target/
hw/chisel/project/target/
hw/chisel/project/project/
hw/chisel/generated/
hw/chisel/.bsp/
hw/rust/spektre-iron-gate/target/
experimental/gda27_rust/target/
hw/formal/agency_ctrl_prove/
hw/formal/agency_ctrl_cover/
hw/formal/agency_self/
hw/formal/**/.lake/
hw/formal/**/lake-manifest.json

# Yosys / SymbiYosys / Verilator intermediates
hdl/v37/yosys.log
hdl/v37/formal.log
hdl/v37/synth_stats.json
hdl/v37/sigma_pipeline/
hdl/asic/build/
hdl/neuromorphic/build/

# Optional upstream checkouts / model weights (never commit)
external/BitNet/
models/

# Benchmark intermediates (per-run generated artefacts)
benchmarks/v33/metrics_run/
benchmarks/v41/budget_*.json
benchmarks/v4?/*.json
benchmarks/v4?/*.jsonl
benchmarks/v4?/*.png
benchmarks/v50/*.json
benchmarks/v50/*.log
benchmarks/v102/results/
benchmarks/v103/results/
benchmarks/v111/__pycache__/
benchmarks/v122/red_team_report.md
benchmarks/pipeline/data/*.jsonl
benchmarks/pipeline/truthfulqa_817.json

# Training local data/runs
training/v111/data/
training/v111/runs/

# v49 certification coverage outputs (generated)
docs/v49/certification/coverage/*.gcov

# `make coverage-proof-receipt` (gcov probe binary + root artifacts)
creation_os_check_proof_receipt_cov
proof_receipt.gcda
proof_receipt.gcno
proof_receipt.c.gcov
docs/v49/certification/coverage/html/

# Paper PDF compile byproducts (the .tex sources ARE tracked)
docs/papers/creation_os_v1.aux
docs/papers/creation_os_v1.log
docs/papers/creation_os_v1.out
docs/papers/creation_os_v1.pdf
docs/papers/creation_os_v1.toc

# Frama-C WP full logs (keep summary under hw/formal/v259/)
docs/v259/frama_c_wp_full.log

# DEV-1 bitnet_server test harnesses (built ad-hoc; live harness needs model)
/test_bitnet_server
/test_bitnet_server_parse

# ------------------------------------------------------------------
# Repo hygiene — build artefacts, runtime data, benchmark outputs (2026-04)
# ------------------------------------------------------------------

# Build artifacts (subset; root cos/kernel binaries remain under rules above)
*.a
creation_os_check_*
/creation_os_cos_memory

# Duplicate cos entrypoints sometimes emitted by local builds (also see /cos-* above)
/cos-chat
/cos-omega
/cos-monitor
/cos-demo
/cos-cache
/cos-bench-*
/cos-evolve
/cos-self-play
/cos-calibrate

# Runtime data
*.db
*.bin
*.jsonl
!benchmarks/lm_eval/fixtures/tiny_hellaswag_sample.jsonl
*.gguf

# Editor / OS junk (macOS duplicates already excluded above)
*.swp
*~

# Third-party build trees (upstream weights stay local only)
third_party/bitnet/build/
third_party/bitnet/models/

# Operator compliance / weekly reports (generated; keep directory)
reports/*.md
reports/*.pdf
!reports/.gitkeep

# TruthfulQA MC1 JSON is large; fetch with scripts/real/truthfulqa_sigma.sh
benchmarks/truthfulqa/mc_task.json

# Benchmark outputs (keep scripts under benchmarks/** — ignore generated reports)
benchmarks/*/results/
benchmarks/qwen_first_contact/*.txt
benchmarks/qwen_first_contact/*.csv
benchmarks/omega_campaign/*.txt
benchmarks/omega_campaign/*.csv
benchmarks/speed/
benchmarks/forgetting/*.csv
benchmarks/forgetting/*.txt
benchmarks/**/*.txt
benchmarks/**/*.csv
# Tracked σ separation pipeline artifacts (canonical run for REPORT.md)
!benchmarks/sigma_separation/pipeline_results.csv
!benchmarks/sigma_separation/chart.txt
# Tracked evolve campaign receipts (5×10 σ_mean run)
!benchmarks/evolve_campaign/*.txt
!benchmarks/evolve_campaign/*.csv
# Graded σ benchmark (tracked prompt list; run `graded_benchmark.sh` for CSV/MD)
!benchmarks/graded/graded_prompts.csv
!benchmarks/graded/graded_50_prompts.csv
!benchmarks/graded/graded_results.csv
!benchmarks/graded/graded_comparison.md
!benchmarks/graded/risk_coverage.csv
!benchmarks/graded/conformal_thresholds.csv
!benchmarks/graded/RESULTS.md
!benchmarks/graded/temperature.txt
!benchmarks/graded/platt.txt
!benchmarks/truthfulqa/truthfulqa_results.csv
!benchmarks/truthfulqa/prompts_preview.csv
!benchmarks/truthfulqa/cos_bench_prompts.csv
# Tracked lm-eval receipts (subset runs + σ replay summaries)
!benchmarks/lm_eval/receipts/
!benchmarks/lm_eval/receipts/**
