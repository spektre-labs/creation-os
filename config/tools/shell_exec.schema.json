{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "arguments"],
  "properties": {
    "name": { "type": "string", "const": "shell_exec" },
    "arguments": {
      "type": "object",
      "required": ["cmd"],
      "properties": {
        "cmd": { "type": "string" }
      }
    }
  }
}
